# MySQL connection string: mysql://user:password@host:port/database
# Works with MySQL 8+ or MariaDB 10.5+, local or hosted (PlanetScale, RDS,
# Cloud SQL, etc). Create the database itself before running db:push.
DATABASE_URL="mysql://ddms_user:ddms_password@127.0.0.1:3306/ddms"

# Generate a real secret for production: `openssl rand -base64 32`
NEXTAUTH_SECRET="change-this-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Seed credentials for the first Super Admin account
SEED_ADMIN_EMAIL="admin@amarahospital.org"
SEED_ADMIN_PASSWORD="ChangeMe@123"
SEED_ADMIN_NAME="System Administrator"
