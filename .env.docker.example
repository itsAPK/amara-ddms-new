# Copy this file to .env (same folder as docker-compose.yml) and fill in
# real values before running `docker compose up`. This single .env file
# is read both by Docker Compose itself (to fill in ${VARS} below) and
# passed through to the app container.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=changeme-root-password
MYSQL_DATABASE=ddms
MYSQL_USER=ddms_user
MYSQL_PASSWORD=changeme-app-password
MYSQL_PORT=3306

# --- App ---
APP_PORT=3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-this-to-a-long-random-string
# Public URL the app is served at (your domain in production)
NEXTAUTH_URL=http://localhost:3000

# --- First Super Admin (created by `npm run db:seed`) ---
SEED_ADMIN_EMAIL=admin@amarahospital.org
SEED_ADMIN_PASSWORD=ChangeMe@123
SEED_ADMIN_NAME=System Administrator
